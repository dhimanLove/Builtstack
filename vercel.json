{
  "trailingSlash": false,
  "installCommand": "npm install --legacy-peer-deps",
  "build": {
    "env": {
      "PUPPETEER_SKIP_DOWNLOAD": "1",
      "SKIP_PRERENDER": "1"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets|robots\\.txt|sitemap\\.xml|favicon\\.ico|google.*\\.html).*)",
      "destination": "/index.html"
    }
  ]
}